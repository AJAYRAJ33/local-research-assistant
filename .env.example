# Copy this file to .env and fill in values
# NEVER commit .env to git

# Ollama model storage path (set to your 1TB HDD mount point)
OLLAMA_MODELS_PATH=C:\Users\ajayr\.ollama\models

# Model name
MODEL_NAME = "phi3:latest"
# Service URLs (for local dev — use docker-compose service names in containers)
INFERENCE_URL=http://localhost:8000
OLLAMA_URL=http://localhost:11434

# ── GitHub Actions Secrets (set these in GitHub repo Settings > Secrets) ──────
# DOCKERHUB_USERNAME   — your Docker Hub username
# DOCKERHUB_TOKEN      — Docker Hub access token (not your password)
# DEPLOY_HOST          — IP or hostname of your deployment server
# DEPLOY_USER          — SSH username on deployment server
# DEPLOY_SSH_KEY       — private SSH key for deployment (paste full PEM content)
